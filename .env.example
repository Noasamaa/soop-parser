# Optional access token. If set, all /api/* requests need:
#   Header: X-Access-Token: <token>
#   or query: ?token=<token>
ACCESS_TOKEN=

# Optional SOOP account for age-restricted / login-required streams
SOOP_USERNAME=
SOOP_PASSWORD=

# Optional YouTube Netscape cookies.txt (age-restricted / members)
# Example: /data/youtube-cookies.txt  (mount into Docker)
YOUTUBE_COOKIES_FILE=

# Public origin used in absolute play URLs (for poplayer / VLC / other apps).
# Example: https://xxxxxxxxx.xxx
# Leave empty to auto-detect from request Host / X-Forwarded-Host.
PUBLIC_BASE_URL=

# Play session TTL in seconds (proxy tokens)
PLAY_TOKEN_TTL=600

# Upstream HTTP timeouts
HTTP_TIMEOUT=20

# Bind host/port (docker-compose may override)
HOST=0.0.0.0
PORT=8080
